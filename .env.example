# CRM Backend Environment Variables
# Copy this file to .env and fill in your values

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Redis (Upstash)
REDIS_URL=redis://default:YOUR_TOKEN@YOUR_ENDPOINT.upstash.io:6379

# AI Agent (Groq as Primary, Gemini as Fallback)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY
GEMINI_API_KEY=AIzaSy_YOUR_GEMINI_KEY


# Channel Stub Service URL
CHANNEL_SERVICE_URL=http://localhost:3002

# Server
PORT=3001
CRM_RECEIPT_URL=http://localhost:3001/api/receipts
CORS_ORIGIN=http://localhost:3000
